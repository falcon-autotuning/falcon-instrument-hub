# Falcon instrument-hub development environment
# Loaded automatically by direnv (https://direnv.net/).
# Run `direnv allow` once after cloning, then all env vars below are set
# whenever you cd into this directory — no more manual exports needed.

LIBDIR="$PWD/vcpkg_installed/x64-linux-dynamic/lib"

# CGO build environment — needed for `go build` / `go test -tags cgo,falcon_core`
export CGO_ENABLED=1
export PKG_CONFIG_PATH="$LIBDIR/pkgconfig"
export CGO_LDFLAGS="-L$LIBDIR -Wl,-rpath,$LIBDIR"

# Hub vcpkg lib path — used by hub_startup_test.go and the hub binary at runtime
export HUB_VCPKG_LIB="$LIBDIR"

# Runtime dynamic-linker path — needed when running the hub binary directly:
#   ./runtime/bin/instrument-hub start ...
export LD_LIBRARY_PATH="/opt/falcon/lib:$LIBDIR${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
